model Pedidos {
    id          String         @id @default(uuid())
    cliente     String
    pessoas     Int
    dataCriacao DateTime       @default(now())
    ativo       Boolean        @default(true)
    itens       PedidosItens[]
    cartao      Cartoes?       @relation(fields: [cartaoId], references: [id])
    cartaoId    String?
}
